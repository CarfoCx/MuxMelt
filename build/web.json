{
  "appId": "com.carfocx.muxmelt",
  "productName": "MuxMelt",
  "directories": {
    "output": "dist"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "CarfoCx",
      "repo": "MuxMelt"
    }
  ],
  "files": [
    "main.js",
    "preload.js",
    "setup-preload.js",
    "package.json",
    "build/icon.png",
    "src/**/*",
    "renderer/**/*",
    "node-tools/**/*",
    "python/**/*",
    "!python/weights/**",
    "!python/**/__pycache__/**",
    "!**/*.pyc"
  ],
  "asarUnpack": [
    "node_modules/sharp/**",
    "node_modules/@img/**",
    "python/**"
  ],
  "extraResources": [
    {
      "from": "build/bundle/python-env",
      "to": "python-env",
      "filter": ["**/*"]
    },
    {
      "from": "build/bundle/ffmpeg",
      "to": "ffmpeg",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis-web",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.png"
  },
  "nsisWeb": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "deleteAppDataOnUninstall": false,
    "shortcutName": "MuxMelt",
    "menuCategory": "MuxMelt",
    "runAfterFinish": true,
    "installerHeader": "build/installerHeader.bmp",
    "installerSidebar": "build/installerSidebar.bmp",
    "uninstallerSidebar": "build/installerSidebar.bmp",
    "appPackageUrl": "https://github.com/CarfoCx/MuxMelt/releases/latest/download",
    "artifactName": "MuxMelt-${version}-windows-${arch}-web-setup.${ext}"
  }
}
