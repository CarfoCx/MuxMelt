{
  "name": "muxmelt",
  "version": "1.2.2",
  "description": "All-in-one media toolkit with MuxMelt PDF editor",
  "main": "main.js",
  "author": "Chad",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build:nexus": "tsc && vite build",
    "preview": "vite preview",
    "build:full:win": "npm run build:nexus && node build/prepare-python.js full && electron-builder --win --publish never",
    "build:full:mac": "npm run build:nexus && node build/prepare-python.js full && electron-builder --mac --publish never",
    "build:slim:win": "npm run build:nexus && node build/prepare-python.js slim && electron-builder --win --config build/slim.json --publish never",
    "build:slim:mac": "npm run build:nexus && node build/prepare-python.js slim && electron-builder --mac --config build/slim.json --publish never",
    "build:linux": "npm run build:nexus && node build/prepare-python.js slim && electron-builder --linux --config build/slim.json --publish never"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "electron-updater": "^6.3.9",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.363.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.0.379",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.2.2",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.2",
    "vite": "^5.2.2"
  },
  "build": {
    "appId": "com.carfocx.muxmelt",
    "productName": "MuxMelt",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "setup-preload.js",
      "package.json",
      "renderer/**/*",
      "node-tools/**/*",
      "python/**/*",
      "!python/weights/**",
      "!python/**/__pycache__/**",
      "!**/*.pyc"
    ],
    "asarUnpack": [
      "node_modules/@img/**",
      "python/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "MuxMelt-Windows-Setup.${ext}"
    }
  }
}
